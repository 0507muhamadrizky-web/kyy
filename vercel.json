{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.3",
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/((?!api/).*)",
            "destination": "/api/index.php"
        }
    ],
    "outputDirectory": "public"
}
